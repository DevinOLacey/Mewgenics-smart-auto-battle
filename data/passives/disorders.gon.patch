SmartHunter {
    name "Smart Hunter"
    desc "Applies the smart Hunter autobattle brain."
    class Disorder

    1 {
        passives {
            Uncontrollable 1
            ReplaceBrain {
                brain GenericBrain
                decision_weights smart_hunter
                move_weights smart_hunter_move
            }
        }
    }
}

