// --- 1. ATTAQUES ALEATOIRES ET DE ZONE (Securite maximale) ---
// RNGCannon peut avoir des effets inattendus, on le bloque sur les allies et cibles gelees.
RNGCannon.merge { damage_instance { ai_base_score 0 custom_additional_ai_weight consider_aoe effects { Conditional_Speculative { Conditional_Ally { FlatAIBonus -999999 } Conditional_HasStatus { status Freeze FlatAIBonus -999999 } Conditional_Boss { Conditional_HealthThreshold { threshold_flat 5 Else { FlatAIBonus -999999 } } } } } } }
RNGCannon2.merge { damage_instance { ai_base_score 0 custom_additional_ai_weight consider_aoe effects { Conditional_Speculative { Conditional_Ally { FlatAIBonus -999999 } Conditional_HasStatus { status Freeze FlatAIBonus -999999 } Conditional_Boss { Conditional_HealthThreshold { threshold_flat 5 Else { FlatAIBonus -999999 } } } } } } }

// --- 2. COMPETENCES DE CLASSE : METRONOME ---
// Ne doit etre lance que s'il y a des ennemis proches pour eviter de gaspiller le mana.
SmartMetronome.merge { damage_instance { ai_base_score 0  } }
SmartMetronome2.merge { damage_instance { ai_base_score 0  } }

// --- 3. ATTAQUES LEGERES / REPOUSSEMENT ---
Bump.merge { damage_instance { ai_base_score 0 effects { Conditional_Speculative { Conditional_Ally { FlatAIBonus -999999 } Conditional_HasStatus { status Freeze FlatAIBonus -999999 } Conditional_Boss { Conditional_HealthThreshold { threshold_flat 3 Else { FlatAIBonus -999999 } } } } } } }
Bump2.merge { damage_instance { ai_base_score 0 effects { Conditional_Speculative { Conditional_Ally { FlatAIBonus -999999 } Conditional_HasStatus { status Freeze FlatAIBonus -999999 } Conditional_Boss { Conditional_HealthThreshold { threshold_flat 3 Else { FlatAIBonus -999999 } } } } } } }

// --- 4. BUFFS ---
// Pas besoin de spammer le PowerUp s'il n'y a pas de danger.
PowerUp.merge { damage_instance { ai_base_score 10  } }
PowerUp2.merge { damage_instance { ai_base_score 10  } }