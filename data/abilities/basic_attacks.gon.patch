// =====================================================================
// SMART_AUTOBATTLE : BASIC_ATTACKS.GON.PATCH
// =====================================================================
// Prevents the AI from using basic attacks on frozen enemies
// (frozen enemies are immune to damage)

// --- BASIC MELEE ATTACKS ---
BasicMelee.merge { damage_instance { ai_base_score 0 effects { Conditional_Speculative { Conditional_HasStatus { status Freeze FlatAIBonus -999999 } } } } }
BasicMelee_Fighter.merge { damage_instance { ai_base_score 0 effects { Conditional_Speculative { Conditional_HasStatus { status Freeze FlatAIBonus -999999 } } } } }
BasicBigMelee.merge { damage_instance { ai_base_score 0 effects { Conditional_Speculative { Conditional_HasStatus { status Freeze FlatAIBonus -999999 } } } } }

