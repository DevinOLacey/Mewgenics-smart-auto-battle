// Monk abilities AI patches
// Porcupine: Thorns+Brace cumulables, expirent après 1 tour (expires_on_appliers_turn true)
// tile_close_to_enemy: inutile sans ennemi adjacent
// ai_base_score -15: décourage fortement le spam — l'offensif doit toujours scorer plus haut
Porcupine.merge {
    damage_instance {
        custom_additional_ai_weight tile_close_to_enemy
        ai_base_score -15
    }
}

// Porcupine2: même logique
Porcupine2.merge {
    damage_instance {
        custom_additional_ai_weight tile_close_to_enemy
        ai_base_score -15
    }
}

// Meditate: self-buff that heals + gives Shield BUT also inflicts Sleep 8 turns — never use in auto-battle
Meditate.merge {
    damage_instance {
        ai_base_score -99999
    }
}

// Meditate2: same as Meditate (mana 6 instead of 8), same sleep problem
Meditate2.merge {
    damage_instance {
        ai_base_score -99999
    }
}
