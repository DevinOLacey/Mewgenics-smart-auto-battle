// --- DEFAULT SAFE Fallback -- never attacks allies ---
smart_default.merge {
    damage_ally -12
    damage_enemy 2
    heal_ally 0
    heal_enemy -8
    kill_enemy 5
    kill_ally -12
    debuff_ally -8
    buff_ally 1
    debuff_enemy 1
    buff_enemy -8
    damage_self -1
    heal_self 1
    buff_self 1
    debuff_self -1
    damage_ally_corpse 0
    damage_enemy_corpse 0
    revive_ally_corpse 1
    revive_enemy_corpse -1
    spawn_object 1
    spawn_object_distance_to_enemy -.01
    spawn_object_distance_to_ally .0001
    negative_weight_scale .99
    spend_mana_scale .30
    consider_total_damage true
    consider_secondary_damage true
    accurate_knockback false
    consider_overkill true
}

// --- HUNTER Ranged Control / Familiars ---
smart_hunter.merge {
    damage_ally -12
    damage_enemy 2
    heal_ally 1
    heal_enemy -8
    kill_enemy 10
    kill_ally -12
    debuff_ally -8
    buff_ally 1
    debuff_enemy 2
    buff_enemy -8
    damage_self -2
    heal_self 1
    buff_self 1
    debuff_self -2
    damage_ally_corpse 0
    damage_enemy_corpse 2
    revive_ally_corpse 1
    revive_enemy_corpse -1
    // Hunters should value deployables, but creature summons and hazards are mainly sorted by their per-ability scores.
    spawn_object 0
    spawn_object_distance_to_enemy -.05
    // Favor placing traps farther from allies to reduce accidental self-triggering.
    spawn_object_distance_to_ally 1
    spawn_object_preferred_distance 4
    negative_weight_scale .99
    // Be less stingy with mana so high-value summons are not skipped too easily.
    spend_mana_scale .10
    consider_total_damage true
    consider_secondary_damage true
    consider_aoe true
    accurate_knockback false
    consider_overkill true
}

