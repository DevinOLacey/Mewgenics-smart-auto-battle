smart_hunter_move.merge {
    distance_to_enemy -1
    distance_to_ally 0
    distance_to_character 0
    preferred_distance reach  // Portée d'arme maximale [cite: 59]
    total_distance_moved 0.01
    face_closest_enemy 1
    danger_avoidance 3        // Reste à distance, évite les tuiles dangereuses
    tall_grass 1              // Se cache dans l'herbe haute si possible
}

smart_fighter_move.merge {
    distance_to_enemy -2    // Cherche frénétiquement le contact [cite: 56]
    distance_to_ally 0
    distance_to_character 0
    preferred_distance 0
    total_distance_moved 0.01
    face_closest_enemy 1
    danger_avoidance 1      // Fonce quand même — accepte le risque
}

smart_tank_move.merge {
