}


// --- FRONT LINE AND SUPPORT ---
// Goal: The Tank physically blocks while the Cleric hides behind it.

smart_tank_move.merge {
    // Pushed to -2 to force contact and block corridors
    distance_to_enemy -2
    distance_to_ally -1.5
    distance_to_character 0
    preferred_distance 0
    total_distance_moved 0
    face_closest_enemy 1
    // Adjusted to 1.5: protects the team without suiciding into a Death Worm
    danger_avoidance 1.5
}

smart_cleric_move.merge {
    distance_to_enemy 1
    distance_to_ally -3
    distance_to_character 2
    distance_to_corpse 4
    preferred_distance 0
    total_distance_moved 0
    face_closest_enemy 1
    danger_avoidance 3
}


