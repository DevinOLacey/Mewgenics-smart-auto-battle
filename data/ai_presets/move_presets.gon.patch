// --- KITING SPECIALISTS ---
// Goal: Keep the target at the absolute edge of range to escape entities with 3 movement (for example: Carnibulb).

smart_hunter_move.merge {
    distance_to_enemy -1
    distance_to_ally 0
    distance_to_character 0
    // Force max-spacing kiting: preferred distance is movement plus ability reach.
    preferred_distance mov+reach
    // Reduce micro-drift while still preferring max-range spacing.
    total_distance_moved 0
    face_closest_enemy 1
    danger_avoidance 4
    // Increased to 5 (inspired by prefer_tall_grass_always_move [cite: 6]) to maximize evasion
    tall_grass 5
}

smart_mage_move.merge {
    distance_to_enemy 3
    distance_to_ally 0
    distance_to_character 0
    // Maximum kiting
    preferred_distance mov+reach
    // Keep enough movement to re-space, but not so much that the mage spends every turn drifting.
    total_distance_moved 0
    face_closest_enemy 1
    danger_avoidance 4
}

smart_psychic_move.merge {
    distance_to_enemy 3
    distance_to_ally -1
    distance_to_character 0
    // Replaces the fixed "8" with dynamic mov+reach logic
    preferred_distance mov+reach
    total_distance_moved 0
    face_closest_enemy 1
    danger_avoidance 3
}

smart_tinkerer_move.merge {
    distance_to_enemy -1
    distance_to_ally 0
    distance_to_character 0
