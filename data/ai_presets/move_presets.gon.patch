// --- SPECIAL AND EXTREME CLASSES ---

smart_thief_move.merge {
    // Default to skirmishing at 3 tiles; melee should happen when an ability-specific score
    // makes a backstab or other high-value dive clearly worth it.
    distance_to_enemy 2
    distance_to_ally 0
    distance_to_character 0
    preferred_distance 3
    // Keep enough movement freedom to find ranged angles or opportunistic backstab lines
    // without overvaluing extreme circling every turn.
    total_distance_moved 0
    face_closest_enemy 1
    danger_avoidance 3
    tall_grass 5
}

smart_jester_move.merge {
    distance_to_enemy -1
    distance_to_ally 0
    distance_to_character 0
    preferred_distance 2
    total_distance_moved 0
    face_closest_enemy 1
    // Pushed to 6 (inspired by bat_chaos_runaway [cite: 9, 10]) for unpredictable pathfinding
    randomness 6
    danger_avoidance 2
}

smart_druid_move.merge {
    distance_to_enemy 0
    distance_to_ally -1
    distance_to_character 0
    preferred_distance reach
    total_distance_moved 0
    face_closest_enemy 1
    danger_avoidance 3
    // Pushed to 5 to root itself in tall grass [cite: 6]
    tall_grass 5
}

smart_necromancer_move.merge {
    distance_to_enemy 1
    // Strong corpse pull, but not so extreme that all other movement logic stops mattering.
    distance_to_corpse -4
    distance_to_ally 0
    distance_to_character 0
    preferred_distance mov
    total_distance_moved 0
    face_closest_enemy 1
    danger_avoidance 3
}
